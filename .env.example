# ─────────────────────────────────────────────────────────────
# TEMPLATE LINGKUNGAN PENGEMBANGAN (ENV TEMPLATE)
# Salin file ini menjadi `.env.local` dan isi dengan nilai Anda sendiri.
# File `.env.local` sudah diabaikan (.gitignored) agar tidak terunggah ke Git.
# ─────────────────────────────────────────────────────────────

# Kunci Privat untuk Menandatangani Rilis Aplikasi (Ed25519)
# Diperoleh dengan menjalankan: npm run tauri signer generate
TAURI_SIGNING_PRIVATE_KEY=TEMPEL_PRIVATE_KEY_ANDA_DI_SINI

# Password Pelindung Kunci Privat (Kosongkan jika kunci tidak menggunakan password)
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
