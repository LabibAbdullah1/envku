{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Envku",
  "version": "1.3.5",
  "identifier": "com.envku.orchestrator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Envku Orchestrator",
        "width": 1024,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Envku - Initializing",
        "url": "/?splash=true",
        "width": 420,
        "height": 450,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "center": true,
        "alwaysOnTop": true,
        "visible": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "template": "installer.nsi",
        "languages": ["Indonesian", "English"],
        "displayLanguageSelector": true,
        "customLanguageFiles": {
          "Indonesian": "custom-indonesian.nsh",
          "English": "custom-english.nsh"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://envku.subly.my.id/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0QTA3MjFBNENDN0E3QjAKUldTd3A4ZE1HbktnaEJ1V0gwWUF0RHl2K3BsZnV6a1dmcTNCREJlcThpVEZySXBMSjJrdllwamoK"
    }
  }
}