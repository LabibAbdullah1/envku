LangString choowHowToInstall ${LANG_INDONESIAN} "Pilih cara menginstal ${PRODUCTNAME}."
LangString createDesktop ${LANG_INDONESIAN} "Buat pintasan di Desktop"
LangString dontUninstall ${LANG_INDONESIAN} "Jangan hapus instalasi (uninstal)"
